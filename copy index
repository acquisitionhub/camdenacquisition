<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Missed Call Revenue Calculator | Dental Practices</title>
<meta name="description" content="Discover exactly how much revenue your dental practice loses from missed calls every month.">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  :root {
    --ink:    #0e1a1c;
    --ink2:   #2a3e41;
    --ink3:   #4a6366;
    --paper:  #f4f0e8;
    --paper2: #ece8df;
    --paper3: #e2ddd3;
    --teal:   #0d6b61;
    --teal-l: #138a7d;
    --teal-ll:#e2f2f0;
    --gold:   #c8832a;
    --gold-l: #f5c46e;
    --gold-ll:#fdf3e3;
    --red:    #c0392b;
    --serif:  'DM Serif Display', Georgia, serif;
    --sans:   'DM Sans', sans-serif;
    --ease:   cubic-bezier(.4,0,.2,1);
    --shadow: 0 2px 12px rgba(14,26,28,.08), 0 1px 3px rgba(14,26,28,.06);
    --shadow-lg: 0 8px 40px rgba(14,26,28,.12), 0 2px 8px rgba(14,26,28,.08);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--sans);
    background: var(--paper);
    color: var(--ink);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Subtle grain overlay */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
    opacity: .025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px;
  }

  /* Decorative teal band at top */
  .top-band {
    height: 4px;
    background: linear-gradient(90deg, var(--teal) 0%, var(--gold) 100%);
  }

  .page {
    max-width: 560px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  /* ── Header ── */
  .site-header {
    padding: 52px 0 40px;
    text-align: center;
    position: relative;
  }

  .eyebrow {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--teal);
    border-bottom: 1.5px solid var(--teal);
    padding-bottom: 3px;
    margin-bottom: 20px;
  }

  .hero-title {
    font-family: var(--serif);
    font-size: clamp(32px, 7vw, 52px);
    line-height: 1.08;
    color: var(--ink);
    margin-bottom: 14px;
  }

  .hero-title em {
    font-style: italic;
    color: var(--teal);
  }

  .hero-sub {
    font-size: 14.5px;
    color: var(--ink3);
    font-weight: 300;
    line-height: 1.6;
  }

  /* ── Stepper ── */
  .stepper {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 32px 0;
    gap: 0;
  }

  .s-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .s-dot {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1.5px solid var(--paper3);
    background: var(--paper);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 600;
    color: var(--ink3);
    transition: all .3s var(--ease);
  }

  .s-dot.active {
    background: var(--teal);
    border-color: var(--teal);
    color: #fff;
    box-shadow: 0 0 0 5px rgba(13,107,97,.12);
  }

  .s-dot.done {
    background: var(--teal-ll);
    border-color: var(--teal);
    color: var(--teal);
  }

  .s-dot.done::after {
    content: '✓';
    font-size: 12px;
  }

  .s-dot.done span { display: none; }

  .s-lbl {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--ink3);
    transition: color .3s;
  }

  .s-lbl.active { color: var(--teal); font-weight: 600; }

  .s-line {
    flex: 1;
    height: 1px;
    background: var(--paper3);
    max-width: 60px;
    margin-bottom: 18px;
    transition: background .4s;
  }

  .s-line.done { background: var(--teal); }

  /* ── Panels ── */
  .panel { display: none; }
  .panel.on { display: block; animation: rise .4s var(--ease) both; }

  @keyframes rise {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0);    }
  }

  /* ── Card ── */
  .card {
    background: #fff;
    border: 1px solid var(--paper3);
    border-radius: 20px;
    padding: 36px;
    box-shadow: var(--shadow);
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--teal), var(--gold));
  }

  .card-title {
    font-family: var(--serif);
    font-size: 22px;
    color: var(--ink);
    margin-bottom: 26px;
  }

  /* ── Fields ── */
  .field { margin-bottom: 20px; }

  .field label {
    display: block;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--ink3);
    margin-bottom: 7px;
  }

  .field input[type="text"],
  .field input[type="email"],
  .field input[type="number"] {
    width: 100%;
    background: var(--paper);
    border: 1.5px solid var(--paper3);
    border-radius: 10px;
    padding: 12px 15px;
    font-size: 15px;
    font-family: var(--sans);
    color: var(--ink);
    outline: none;
    transition: border-color .2s;
  }

  .field input:focus {
    border-color: var(--teal);
    background: #fff;
  }

  .err {
    font-size: 11.5px;
    color: var(--red);
    margin-top: 5px;
    display: none;
    font-weight: 500;
  }

  .err.on { display: block; }

  /* ── Slider section ── */
  .slider-big {
    font-family: var(--serif);
    font-size: 72px;
    color: var(--teal);
    text-align: center;
    line-height: 1;
    letter-spacing: -.02em;
  }

  .slider-unit {
    text-align: center;
    font-size: 11px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--ink3);
    margin: 4px 0 20px;
  }

  input[type="range"] {
    -webkit-appearance: none;
    width: 100%;
    height: 4px;
    background: var(--paper3);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }

  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--teal);
    cursor: pointer;
    box-shadow: 0 0 0 4px rgba(13,107,97,.15);
    transition: box-shadow .2s;
  }

  input[type="range"]::-webkit-slider-thumb:hover {
    box-shadow: 0 0 0 7px rgba(13,107,97,.18);
  }

  /* ── Live ticker ── */
  .ticker {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--teal-ll);
    border-top: 2px solid rgba(13,107,97,.2);
    margin: 28px -36px -36px;
    padding: 16px 36px;
    border-radius: 0 0 19px 19px;
  }

  .ticker-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--teal);
  }

  .ticker-val {
    font-family: var(--serif);
    font-size: 32px;
    color: var(--teal);
    letter-spacing: -.01em;
  }

  /* ── Buttons ── */
  .btn {
    display: block;
    width: 100%;
    padding: 15px 20px;
    border-radius: 10px;
    border: none;
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all .2s var(--ease);
    text-align: center;
    margin-top: 16px;
    letter-spacing: .01em;
  }

  .btn-teal {
    background: var(--teal);
    color: #fff;
  }

  .btn-teal:hover {
    background: var(--teal-l);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(13,107,97,.25);
  }

  .btn-gold {
    background: var(--gold);
    color: #fff;
  }

  .btn-gold:hover {
    background: #b3751f;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(200,131,42,.3);
  }

  .btn:disabled {
    opacity: .6;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  /* ── Results ── */
  .result-header {
    text-align: center;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--paper3);
    margin-bottom: 28px;
  }

  .result-eyebrow {
    font-size: 10.5px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--ink3);
    margin-bottom: 8px;
    font-weight: 500;
  }

  .result-loss {
    font-family: var(--serif);
    font-size: 72px;
    color: var(--teal);
    line-height: 1;
    letter-spacing: -.02em;
    margin-bottom: 8px;
  }

  .result-annual {
    font-size: 16px;
    color: var(--ink3);
  }

  .result-annual strong {
    color: var(--gold);
    font-weight: 600;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 24px;
  }

  .stat {
    background: var(--paper);
    border: 1px solid var(--paper3);
    border-radius: 12px;
    padding: 18px;
    text-align: center;
  }

  .stat-v {
    font-family: var(--serif);
    font-size: 26px;
    color: var(--teal);
    line-height: 1.1;
    margin-bottom: 4px;
  }

  .stat-lbl {
    font-size: 11.5px;
    color: var(--ink3);
    font-weight: 500;
    letter-spacing: .04em;
  }

  .insight {
    background: var(--gold-ll);
    border-left: 3px solid var(--gold);
    border-radius: 0 10px 10px 0;
    padding: 14px 16px;
    font-size: 14px;
    color: var(--ink2);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* ── CTA block ── */
  .cta-wrap {
    background: #fff;
    border: 1px solid var(--paper3);
    border-radius: 20px;
    padding: 32px;
    margin-top: 16px;
    text-align: center;
    box-shadow: var(--shadow);
    position: relative;
    overflow: hidden;
  }

  .cta-wrap::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--teal));
  }

  .cta-title {
    font-family: var(--serif);
    font-size: 22px;
    margin-bottom: 8px;
    color: var(--ink);
  }

  .cta-sub {
    font-size: 14px;
    color: var(--ink3);
    margin-bottom: 22px;
    line-height: 1.6;
  }

  .recalc {
    display: block;
    text-align: center;
    margin-top: 14px;
    color: var(--ink3);
    font-size: 13px;
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    font-weight: 500;
    background: none;
    border: none;
    width: 100%;
  }

  .recalc:hover { color: var(--ink); }

  /* ── Spinner ── */
  .spinner {
    display: inline-block;
    width: 16px; height: 16px;
    border: 2px solid rgba(255,255,255,.4);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin .6s linear infinite;
    vertical-align: middle;
    margin-right: 6px;
  }

  @keyframes spin { to { transform: rotate(360deg); } }
</style>
</head>

<body>

<div class="top-band"></div>

<div class="page">

  <header class="site-header">
    <div class="eyebrow">Dental Revenue Tool</div>
    <h1 class="hero-title">How much is your practice<br><em>losing</em> from missed calls?</h1>
    <p class="hero-sub">Fill in two numbers. Get your answer in under a minute.</p>
  </header>

  <!-- Stepper -->
  <nav class="stepper">
    <div class="s-node">
      <div class="s-dot active" id="c1"><span>1</span></div>
      <div class="s-lbl active" id="l1">Details</div>
    </div>
    <div class="s-line" id="b1"></div>
    <div class="s-node">
      <div class="s-dot" id="c2"><span>2</span></div>
      <div class="s-lbl" id="l2">Calculate</div>
    </div>
    <div class="s-line" id="b2"></div>
    <div class="s-node">
      <div class="s-dot" id="c3"><span>3</span></div>
      <div class="s-lbl" id="l3">Results</div>
    </div>
  </nav>

  <!-- Step 1: Details -->
  <div class="panel on" id="p1">
    <div class="card">
      <h2 class="card-title">Your practice details</h2>
      <div class="field">
        <label for="fname">Your name</label>
        <input type="text" id="fname" placeholder="Dr. Sarah Jones" autocomplete="name">
        <span class="err" id="err-name">Please enter your name.</span>
      </div>
      <div class="field">
        <label for="email">Email address</label>
        <input type="email" id="email" placeholder="sarah@practice.co.uk" autocomplete="email">
        <span class="err" id="err-email">Please enter a valid email address.</span>
      </div>
      <div class="field">
        <label for="pname">Practice name <span style="font-weight:400;text-transform:none;letter-spacing:0">(optional)</span></label>
        <input type="text" id="pname" placeholder="Smile Dental" autocomplete="organization">
      </div>
    </div>
    <button class="btn btn-teal" id="btn1" onclick="next1()">Continue to Calculator →</button>
  </div>

  <!-- Step 2: Sliders -->
  <div class="panel" id="p2">
    <div class="card">
      <div class="field">
        <label>Calls missed per day</label>
        <div class="slider-big" id="snum">5</div>
        <div class="slider-unit">calls / day</div>
        <input type="range" id="slider" min="1" max="30" value="5" step="1" oninput="onSlide(this)">
      </div>
      <div class="field" style="margin-top:28px">
        <label for="pval">Average patient value (£)</label>
        <input type="number" id="pval" value="250" min="1" step="1" oninput="onValue()">
        <span class="err" id="err-val">Please enter a patient value.</span>
      </div>
      <div class="ticker">
        <span class="ticker-label">Est. monthly loss</span>
        <div class="ticker-val" id="live">£37,500</div>
      </div>
    </div>
    <button class="btn btn-teal" id="btn2" onclick="calc()">Calculate My Results →</button>
  </div>

  <!-- Step 3: Results -->
  <div class="panel" id="p3">
    <div class="card">
      <div class="result-header">
        <p class="result-eyebrow">Your estimated monthly loss</p>
        <div class="result-loss" id="r-monthly">£0</div>
        <p class="result-annual">That's <strong id="r-annual">£0</strong> per year you're leaving behind.</p>
      </div>
      <div class="stats-grid">
        <div class="stat">
          <div class="stat-v" id="s-calls">0</div>
          <div class="stat-lbl">Missed calls / month</div>
        </div>
        <div class="stat">
          <div class="stat-v" id="s-pv">£0</div>
          <div class="stat-lbl">Per patient value</div>
        </div>
      </div>
      <div class="insight">
        Most of this revenue is already within reach — it just needs someone to answer the phone.
      </div>
    </div>

    <div class="cta-wrap">
      <h3 class="cta-title">Ready to recover this revenue?</h3>
      <p class="cta-sub">See how practices like yours are capturing missed calls and turning them into booked appointments — automatically.</p>
      <button class="btn btn-gold" onclick="demo()">See How It Works →</button>
      <button class="recalc" onclick="location.reload()">Start over</button>
    </div>
  </div>

</div><!-- /page -->

<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>

<script>
  /* ── EmailJS init ── */
  emailjs.init({ publicKey: "Q2eKuuLp_3c7mdLC6" });

  /* ── State ── */
  let missed  = 5;
  let patVal  = 250;
  let leadName, leadEmail, leadPractice;

  /* ── Helpers ── */
  function fmt(n) { return '£' + Math.round(n).toLocaleString('en-GB'); }

  function showErr(id) { document.getElementById(id).classList.add('on'); }
  function hideErr(id) { document.getElementById(id).classList.remove('on'); }

  function setLoading(btnId, loading) {
    const btn = document.getElementById(btnId);
    if (loading) {
      btn.disabled = true;
      btn.dataset.orig = btn.innerHTML;
      btn.innerHTML = '<span class="spinner"></span> Sending…';
    } else {
      btn.disabled = false;
      btn.innerHTML = btn.dataset.orig;
    }
  }

  /* ── Step 1 ── */
  function next1() {
    leadName     = document.getElementById('fname').value.trim();
    leadEmail    = document.getElementById('email').value.trim();
    leadPractice = document.getElementById('pname').value.trim() || 'Not provided';

    let ok = true;
    if (!leadName)                          { showErr('err-name');  ok = false; } else hideErr('err-name');
    if (!leadEmail || !leadEmail.includes('@')) { showErr('err-email'); ok = false; } else hideErr('err-email');
    if (!ok) return;

    go(2);
  }

  /* ── Step 2 sliders ── */
  function onSlide(el) {
    missed = parseInt(el.value, 10);
    document.getElementById('snum').textContent = missed;
    updateLive();
  }

  function onValue() {
    patVal = parseFloat(document.getElementById('pval').value) || 0;
    updateLive();
  }

  function updateLive() {
    document.getElementById('live').textContent = fmt(missed * patVal * 30);
  }

  /* ── Step 2 → 3: send email + show results ── */
  async function calc() {
    const pv  = parseFloat(document.getElementById('pval').value);
    if (!pv || pv <= 0) { showErr('err-val'); return; }
    hideErr('err-val');

    const mo = Math.round(missed * pv * 30);
    const yr = mo * 12;

    setLoading('btn2', true);

    try {
      const result = await emailjs.send(
        'service_s6stsxi',
        'template_tu7pr0j',
        {
          to_name:       leadName,
          to_email:      leadEmail,
          practice_name: leadPractice,
          missed_per_day: missed,
          patient_value:  fmt(pv),
          monthly_loss:   fmt(mo),
          annual_loss:    fmt(yr)
        }
      );
      console.log('EmailJS success:', result.status, result.text);
    } catch (err) {
      console.error('EmailJS error:', err);
      /* Don't block the user — show results regardless */
    } finally {
      setLoading('btn2', false);
    }

    /* Update results panel */
    document.getElementById('r-monthly').textContent = fmt(mo);
    document.getElementById('r-annual').textContent  = fmt(yr);
    document.getElementById('s-calls').textContent   = (missed * 30).toLocaleString('en-GB');
    document.getElementById('s-pv').textContent      = fmt(pv);

    go(3);
  }

  /* ── Stepper navigation ── */
  function go(n) {
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('on'));
    document.getElementById('p' + n).classList.add('on');

    /* Activate current step */
    document.getElementById('c' + n).classList.add('active');
    document.getElementById('l' + n).classList.add('active');

    /* Mark previous steps done */
    if (n > 1) {
      document.getElementById('c1').classList.remove('active');
      document.getElementById('c1').classList.add('done');
      document.getElementById('b1').classList.add('done');
    }
    if (n > 2) {
      document.getElementById('c2').classList.remove('active');
      document.getElementById('c2').classList.add('done');
      document.getElementById('b2').classList.add('done');
    }

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  /* ── CTA ── */
  function demo() {
    window.open('https://patientacquisitionhub.com/missed-call.html', '_blank');
  }
</script>
</body>
</html>
